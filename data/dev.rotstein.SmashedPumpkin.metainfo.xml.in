<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID@</id>
  <name>@APP_NAME@</name>
  <summary>Manage Pumpkin Minecraft servers in GNOME style</summary>
  <summary xml:lang="de">Pumpkin-Minecraft-Server im GNOME-Stil verwalten</summary>
  <description>
    <p>Smashed Pumpkin is a GNOME-style app for managing your Pumpkin Minecraft server.</p>
    <p>It helps you run and maintain your server and checks automatically for new updates.</p>
  </description>
  <description xml:lang="de">
    <p>Smashed Pumpkin ist eine App im GNOME-Stil zur Verwaltung deines Pumpkin-Minecraft-Servers.</p>
    <p>Sie hilft dir beim Betrieb und bei der Pflege deines Servers und sucht automatisch nach Updates.</p>
  </description>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer_name>Rotstein</developer_name>
  <branding>
    <color type="primary">#FA8213</color>
  </branding>
  <url type="homepage">https://github.com/Rotstein007/smashed-pumpkin</url>
  <url type="bugtracker">https://github.com/Rotstein007/smashed-pumpkin/issues</url>
  <url type="vcs-browser">https://github.com/Rotstein007/smashed-pumpkin</url>
  <launchable type="desktop-id">@APP_ID@.desktop</launchable>
  <content_rating type="oars-1.1"/>
  <screenshots>
    <screenshot type="default">
      <image type="source">https://raw.githubusercontent.com/Rotstein007/smashed-pumpkin/master/data/screenshots/smashed-pumpkin-console.png</image>
      <caption xml:lang="en">Server console</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/Rotstein007/smashed-pumpkin/master/data/screenshots/smashed-pumpkin-stats.png</image>
      <caption xml:lang="en">Resource stats</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/Rotstein007/smashed-pumpkin/master/data/screenshots/smashed-pumpkin-logs.png</image>
      <caption xml:lang="en">Log files</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/Rotstein007/smashed-pumpkin/master/data/screenshots/smashed-pumpkin-plugins.png</image>
      <caption xml:lang="en">Plugin manager</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/Rotstein007/smashed-pumpkin/master/data/screenshots/smashed-pumpkin-worlds.png</image>
      <caption xml:lang="en">Worlds</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://raw.githubusercontent.com/Rotstein007/smashed-pumpkin/master/data/screenshots/smashed-pumpkin-settings.png</image>
      <caption xml:lang="en">Server settings</caption>
    </screenshot>
  </screenshots>
  <requires>
    <display_length compare="ge">600</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <releases>
    <release version="0.4.1" date="2026-03-04">
      <description>
        <ul>
          <li>Player management is much more stable: search, sorting, and admin actions are more reliable.</li>
          <li>Moderation was expanded with ban reasons plus ban-ip and pardon-ip flows.</li>
          <li>The console was refined with clearer timestamps, better filters, and less noisy output.</li>
          <li>New per-server Domains tab with Java/Bedrock DNS guidance and Dynamic DNS options.</li>
          <li>Desktop release pipeline now ships Flatpak (x86_64 + aarch64), Windows MSI (x64), and macOS app bundles.</li>
          <li>Release publishing is now intentionally manual with strict version consistency checks.</li>
        </ul>
        <p>Android/APK was evaluated, but is not release-ready yet for the current GTK4+libadwaita stack.</p>
      </description>
      <description xml:lang="de">
        <ul>
          <li>Spielerverwaltung deutlich stabiler: Suchen, Sortieren und Admin-Aktionen funktionieren zuverlässiger.</li>
          <li>Moderation wurde ausgebaut: inklusive Ban-Gründen sowie ban-ip und pardon-ip.</li>
          <li>Die Konsole wurde überarbeitet: klarere Zeitstempel, bessere Filter und weniger Stör-Ausgaben.</li>
          <li>Neuer Domains-Tab pro Server mit DNS-Anleitung für Java/Bedrock und Dynamic-DNS-Optionen.</li>
          <li>Desktop-Release-Pipeline erweitert: Flatpak (x86_64 + aarch64), Windows MSI (x64) und macOS App-Bundles.</li>
          <li>Release-Veröffentlichung ist jetzt bewusst manuell steuerbar, inklusive strikter Versionsprüfung.</li>
        </ul>
        <p>Android/APK wurde geprüft, ist für den aktuellen GTK4+libadwaita-Stack aber noch nicht release-reif.</p>
      </description>
    </release>
    <release version="0.4.0" date="2026-02-28">
      <description>
        <ul>
          <li>The Players tab is now fully available with online/offline history, search, and sorting.</li>
          <li>Moderation now includes ban-ip, pardon-ip, and visible ban reasons.</li>
          <li>The console is cleaner and easier to read with improved timestamps and level filters.</li>
          <li>General and server-specific settings are now clearly separated and provide more options.</li>
          <li>Update checks now run automatically on startup and every minute.</li>
          <li>The tray menu now reliably opens the app and still provides Quit.</li>
        </ul>
        <p>This is probably the biggest update so far, and every user feedback message directly helps development!</p>
      </description>
    </release>
    <release version="0.3.0" date="2026-02-26">
      <description>
        <ul>
          <li>The update check now works reliably.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.3" date="2026-02-17">
      <description>
        <ul>
          <li>Tray icons now work reliably in the Flatpak version.</li>
          <li>Background behavior when closing the app has been improved.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-02-16">
      <description>
        <ul>
          <li>Fixed GNOME tray icon visibility by setting a reliable icon theme path.</li>
          <li>Improved tray helper discovery for installed and local build setups.</li>
          <li>Added AppIndicator dependency fallback for broader Linux compatibility.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-01-12">
      <description>
        <ul>
          <li>Console now has a Send button for commands.</li>
          <li>Updated app screenshots.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-01-12">
      <description>
        <ul>
          <li>Tray indicator now stays visible and offers quick server shortcuts.</li>
          <li>Plugin URL download removed; drag-and-drop is the primary install path.</li>
          <li>Console toolbar simplified and window title bar cleaned up.</li>
          <li>Background mode behavior is clearer when closing the window.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-01-05"/>
  </releases>
</component>
