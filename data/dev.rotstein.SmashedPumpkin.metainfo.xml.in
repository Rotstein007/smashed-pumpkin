  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <releases>
    <release version="0.5.2" date="2026-04-06">
      <description>
        <ul>
          <li>Windows port.</li>
          <li xml:lang="de">Windows-Portierung.</li>
        </ul>
        <p>Thank you for your feedback. It directly helps development.</p>
        <p xml:lang="de">Vielen Dank für euer Feedback. Es hilft der Entwicklung direkt weiter.</p>
      </description>
    </release>
    <release version="0.5.1" date="2026-04-04">
      <description>
        <ul>
          <li>Updates are now more reliable and the console shows more clearly which build is being replaced.</li>
          <li xml:lang="de">Updates laufen jetzt zuverlässiger und die Konsole zeigt klarer an, welcher Build ersetzt wird.</li>
          <li>The overview handles server networks more cleanly, with better scrolling behavior and a more consistent visual style.</li>
          <li xml:lang="de">Die Übersicht geht mit Servernetzwerken jetzt sauberer um, scrollt besser und wirkt optisch einheitlicher.</li>
          <li>Server networks now have their own detail view to make larger setups easier to manage.</li>
          <li xml:lang="de">Servernetzwerke haben jetzt eine eigene Detailansicht, damit sich größere Setups übersichtlicher verwalten lassen.</li>
          <li>Flathub metadata, descriptions, and screenshots have been cleaned up and prepared more carefully.</li>
          <li xml:lang="de">Flathub-Metadaten, Beschreibungen und Screenshots wurden bereinigt und sauberer vorbereitet.</li>
        </ul>
        <p>Thank you for your feedback. It directly shaped these fixes.</p>
        <p xml:lang="de">Vielen Dank für euer Feedback. Es hat diese Fehlerbehebungen direkt mitgeprägt.</p>
      </description>
    </release>
    <release version="0.5.0" date="2026-03-29">
      <description>
        <ul>
          <li>The app now feels cleaner and more modern, with a clearer server overview and refined detail views.</li>
          <li xml:lang="de">Die App wirkt jetzt aufgeräumter und moderner, mit einer klareren Serverübersicht und überarbeiteten Detailansichten.</li>
          <li>Plugins, worlds, and server groups are easier to manage, with better actions and less visual clutter.</li>
          <li xml:lang="de">Plugins, Welten und Servergruppen lassen sich angenehmer verwalten, mit besseren Aktionen und weniger visuellem Ballast.</li>
          <li>Networks and player management have been expanded to make larger setups easier to organize.</li>
          <li xml:lang="de">Netzwerke und Spielerverwaltung wurden erweitert, damit sich größere Setups übersichtlicher organisieren lassen.</li>
          <li>Many smaller improvements make updates, restarts, and everyday use more reliable.</li>
          <li xml:lang="de">Viele kleine Verbesserungen machen Updates, Neustarts und den Alltag insgesamt zuverlässiger.</li>
        </ul>
        <p>Thank you for your feedback. It directly shaped this update.</p>
        <p xml:lang="de">Vielen Dank für euer Feedback. Es hat dieses Update direkt mitgeprägt.</p>
      </description>
    </release>
    <release version="0.4.1" date="2026-03-04">
      <description>
        <ul>
          <li>New server networks: You can now manage multiple servers as one group and start, stop, or update them together.</li>
          <li xml:lang="de">Neue Server-Netzwerke: Mehrere Server lassen sich jetzt als Verbund verwalten und gemeinsam starten, stoppen und aktualisieren.</li>
          <li>New Domains tab with Dynamic DNS: DNS records can now be updated automatically when your public IP changes.</li>
          <li xml:lang="de">Neuer Domains-Tab mit Dynamic DNS: Bei wechselnder öffentlicher IP können DNS-Einträge jetzt automatisch aktualisiert werden.</li>
        </ul>
        <p>Thank you to everyone in the community whose feedback directly shaped this update.</p>
        <p xml:lang="de">Vielen Dank für euer Feedback, das diese Funktionen direkt mitgeprägt hat.</p>
      </description>
    </release>
    <release version="0.4.0" date="2026-02-28">
      <description>
        <ul>
          <li>The Players tab is now fully available with online/offline history, search, and sorting.</li>
          <li>Moderation now includes ban-ip, pardon-ip, and visible ban reasons.</li>
          <li>The console is cleaner and easier to read with improved timestamps and level filters.</li>
          <li>General and server-specific settings are now clearly separated and provide more options.</li>
          <li>Update checks now run automatically on startup and every minute.</li>
          <li>The tray menu now reliably opens the app and still provides Quit.</li>
        </ul>
        <p>This is probably the biggest update so far, and every user feedback message directly helps development!</p>
      </description>
    </release>
    <release version="0.3.0" date="2026-02-26">
      <description>
        <ul>
          <li>The update check now works reliably.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.3" date="2026-02-17">
      <description>
        <ul>
          <li>Tray icons now work reliably in the Flatpak version.</li>
          <li>Background behavior when closing the app has been improved.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-02-16">
      <description>
        <ul>
          <li>Fixed GNOME tray icon visibility by setting a reliable icon theme path.</li>
          <li>Improved tray helper discovery for installed and local build setups.</li>
          <li>Added AppIndicator dependency fallback for broader Linux compatibility.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-01-12">
      <description>
        <ul>
          <li>Console now has a Send button for commands.</li>
          <li>Updated app screenshots.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-01-12">
      <description>
        <ul>
          <li>Tray indicator now stays visible and offers quick server shortcuts.</li>
          <li>Plugin URL download removed; drag-and-drop is the primary install path.</li>
          <li>Console toolbar simplified and window title bar cleaned up.</li>
          <li>Background mode behavior is clearer when closing the window.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-01-05"/>
  </releases>
</component>
