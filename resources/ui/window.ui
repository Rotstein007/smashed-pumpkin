                        <child>
                          <object class="AdwViewStackPage">
                            <property name="name">domains</property>
                            <property name="title" translatable="yes">Domains</property>
                            <property name="icon-name">network-wired-symbolic</property>
                            <property name="child">
                              <object class="GtkScrolledWindow">
                                <property name="vexpand">true</property>
                                <child>
                                  <object class="GtkBox" id="domains_page_box">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">12</property>
                                    <property name="margin-top">12</property>
                                    <property name="margin-bottom">18</property>
                                    <property name="margin-start">12</property>
                                    <property name="margin-end">12</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Bind domains per server</property>
                                        <property name="xalign">0</property>
                                        <style><class name="title-4"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Set hostnames for this server. Smashed Pumpkin stores them and shows the DNS records you should configure in your DNS provider (for example Cloudflare, Route53, or your registrar DNS).</property>
                                        <property name="wrap">true</property>
                                        <property name="xalign">0</property>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkEntry" id="entry_domain">
                                        <property name="placeholder-text" translatable="yes">Domain or subdomain (e.g. pumpkin.rotstein.dev)</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="btn_save_domains">
                                        <property name="label" translatable="yes">Save Domain &amp; DDNS Settings</property>
                                        <property name="css-classes">suggested-action</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSeparator"/>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Dynamic DNS (Cloudflare)</property>
                                        <property name="xalign">0</property>
                                        <style><class name="title-4"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Use this if your home IP changes. Smashed Pumpkin will update your Cloudflare DNS record automatically.</property>
                                        <property name="wrap">true</property>
                                        <property name="xalign">0</property>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">8</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Enable DDNS</property>
                                            <property name="xalign">0</property>
                                            <property name="hexpand">true</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkSwitch" id="switch_ddns_enabled">
                                            <property name="halign">end</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkEntry" id="entry_ddns_cf_zone_id">
                                        <property name="placeholder-text" translatable="yes">Cloudflare Zone ID (required)</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkPasswordEntry" id="entry_ddns_cf_api_token">
                                        <property name="placeholder-text" translatable="yes">Cloudflare API Token (required)</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkEntry" id="entry_ddns_cf_record_id">
                                        <property name="placeholder-text" translatable="yes">Cloudflare Record ID (optional, auto-discovered when empty)</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">8</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Proxied (orange cloud)</property>
                                            <property name="xalign">0</property>
                                            <property name="hexpand">true</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkSwitch" id="switch_ddns_cf_proxied">
                                            <property name="halign">end</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">8</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Interval (30-86400 seconds)</property>
                                            <property name="xalign">0</property>
                                            <property name="hexpand">true</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkEntry" id="entry_ddns_interval_seconds">
                                            <property name="width-chars">6</property>
                                            <property name="max-width-chars">6</property>
                                            <property name="input-purpose">digits</property>
                                            <property name="text">300</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">8</property>
                                        <child>
                                          <object class="GtkButton" id="btn_ddns_sync_now">
                                            <property name="label" translatable="yes">Sync now</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="label_ddns_status">
                                            <property name="xalign">0</property>
                                            <property name="hexpand">true</property>
                                            <property name="label" translatable="yes">DDNS disabled.</property>
                                            <property name="wrap">true</property>
                                            <style><class name="dim-label"/></style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSeparator"/>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">DNS setup guide</property>
                                        <property name="xalign">0</property>
                                        <style><class name="title-4"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="label_domains_target">
                                        <property name="label" translatable="yes">Target: your-public-ip (Java:25565, Bedrock:19132)</property>
                                        <property name="xalign">0</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">1) Create one A/AAAA record for your domain to your public server IP.</property>
                                        <property name="wrap">true</property>
                                        <property name="xalign">0</property>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">2) If Java does not use port 25565, add an SRV record: _minecraft._tcp.&lt;domain&gt; with your Java port.</property>
                                        <property name="wrap">true</property>
                                        <property name="xalign">0</property>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">3) For Bedrock on the same domain, add an SRV record: _minecraft._udp.&lt;domain&gt; with your Bedrock port if needed.</property>
                                        <property name="wrap">true</property>
                                        <property name="xalign">0</property>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>

                        <child>
                          <object class="AdwViewStackPage">
                            <property name="name">settings</property>
                            <property name="title" translatable="yes">Settings</property>
                            <property name="icon-name">emblem-system-symbolic</property>
                            <property name="child">
                              <object class="GtkScrolledWindow">
                                <property name="vexpand">true</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">18</property>
                                    <property name="margin-top">6</property>
                                    <property name="margin-bottom">24</property>
                                    <property name="margin-start">6</property>
                                    <property name="margin-end">6</property>

                                    <!-- ========== GENERAL SETTINGS ========== -->
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">General</property>
                                        <property name="xalign">0</property>
                                        <style><class name="title-3"/></style>
                                      </object>
                                    </child>

                                    <!-- Start with system -->
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">8</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Start with system</property>
                                            <property name="xalign">0</property>
                                            <property name="hexpand">true</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkSwitch" id="switch_autostart_on_boot">
                                            <property name="halign">end</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Launch the app automatically when you log in.</property>
                                        <property name="wrap">true</property>
                                        <property name="xalign">0</property>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>

                                    <!-- Start minimized -->
                                    <child>
                                      <object class="GtkBox">
                                        <property name="spacing">8</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Start minimized</property>
                                            <property name="xalign">0</property>
                                            <property name="hexpand">true</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkSwitch" id="switch_start_minimized">
                                            <property name="halign">end</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">App starts hidden in the system tray.</property>
                                        <property name="wrap">true</property>
